{
  "name": "ukrstene-reci",
  "version": "0.0.0",
  "private": true,
  "description": "Ukrstene Reci - a crossword game (backend + mobile monorepo)",
  "workspaces": [
    "backend",
    "mobile"
  ],
  "scripts": {
